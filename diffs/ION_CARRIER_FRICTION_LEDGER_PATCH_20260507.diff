@@ -0,0 +1,269 @@
+"""ION Carrier Friction Ledger v0.
+
+Records structured carrier-friction events without exposing raw chain-of-thought.
+Events are improvement evidence only; Steward/human review decides whether they
+become issues, packets, tests, or accepted repairs.
+"""
+from __future__ import annotations
+
+import json
+import re
+from datetime import datetime, timezone
+from pathlib import Path
+from typing import Any, Mapping
+
+from .ion_carrier_onboard import resolve_shell_root_from_ion_root
+
+SCHEMA_ID = "ion.carrier_friction_ledger.v0"
+EVENT_SCHEMA = "ion.carrier_friction_event.v0"
+READY_VERDICT = "ION_CARRIER_FRICTION_LEDGER_READY"
+BLOCKED_VERDICT = "ION_CARRIER_FRICTION_LEDGER_BLOCKED"
+
+BASE_DIR = Path("ION/05_context/current/carrier_friction")
+EVENTS_DIR = BASE_DIR / "events"
+LEDGER_PATH = BASE_DIR / "ACTIVE_CARRIER_FRICTION_LEDGER.json"
+
+ALLOWED_EVENT_TYPES = {
+    "context_gap",
+    "stale_surface_risk",
+    "authority_ambiguity",
+    "approval_contract_mismatch",
+    "tool_hang",
+    "missing_receipt",
+    "missing_idempotency_status",
+    "response_shape_risk",
+    "template_gap",
+    "proof_gate_gap",
+    "routing_ambiguity",
+    "human_relay_burden",
+    "unnecessary_inference",
+    "product_ux_friction",
+    "test_gap",
+    "documentation_gap",
+    "role_confusion",
+    "package_boundary_confusion",
+    "other",
+}
+
+ALLOWED_SEVERITIES = {
+    "S0_OBSERVATION",
+    "S1_MINOR",
+    "S2_WORKFLOW_FRICTION",
+    "S3_BLOCKING",
+    "S4_STATE_RISK",
+    "S5_SAFETY_AUTHORITY_RISK",
+}
+
+ALLOWED_FIX_CLASSES = {
+    "context",
+    "prompt",
+    "template",
+    "tool",
+    "test",
+    "receipt",
+    "gateway",
+    "mcp",
+    "package",
+    "ux",
+    "documentation",
+    "governance",
+}
+
+ALLOWED_STEWARD_DISPOSITIONS = {
+    "new",
+    "duplicate",
+    "accepted_issue",
+    "rejected",
+    "escalated",
+    "converted_to_codex_packet",
+    "fixed",
+}
+
+
+def _now() -> str:
+    return datetime.now(timezone.utc).replace(microsecond=0).isoformat()
+
+
+def _safe_slug(value: str) -> str:
+    return re.sub(r"[^a-z0-9]+", "_", value.lower()).strip("_")[:96] or "friction_event"
+
+
+def _resolve_root(root: str | Path | None) -> Path:
+    candidate = Path(root or ".").expanduser().resolve()
+    for path in (candidate, *candidate.parents):
+        if (path / "pyproject.toml").exists() and (path / "ION/REPO_AUTHORITY.md").exists():
+            return path
+    return resolve_shell_root_from_ion_root(root)
+
+
+def _write_json(path: Path, value: Mapping[str, Any]) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(json.dumps(value, indent=2, sort_keys=True) + "\n", encoding="utf-8")
+
+
+def _read_json(path: Path) -> dict[str, Any] | None:
+    if not path.exists():
+        return None
+    try:
+        value = json.loads(path.read_text(encoding="utf-8"))
+    except json.JSONDecodeError:
+        return None
+    return value if isinstance(value, dict) else None
+
+
+def validate_friction_event(event: Mapping[str, Any]) -> dict[str, Any]:
+    findings: list[str] = []
+    event_type = str(event.get("event_type") or "").strip()
+    severity = str(event.get("severity") or "").strip()
+    routing = event.get("routing") if isinstance(event.get("routing"), Mapping) else {}
+    fix_class = str(event.get("fix_class") or routing.get("fix_class") or "").strip()
+    disposition = str(event.get("steward_disposition") or routing.get("steward_disposition") or "new").strip() or "new"
+
+    if event.get("schema") != EVENT_SCHEMA:
+        findings.append("schema_must_be_ion_carrier_friction_event_v0")
+    if event_type not in ALLOWED_EVENT_TYPES:
+        findings.append(f"event_type_not_allowed:{event_type or 'missing'}")
+    if severity not in ALLOWED_SEVERITIES:
+        findings.append(f"severity_not_allowed:{severity or 'missing'}")
+    if fix_class and fix_class not in ALLOWED_FIX_CLASSES:
+        findings.append(f"fix_class_not_allowed:{fix_class}")
+    if disposition not in ALLOWED_STEWARD_DISPOSITIONS:
+        findings.append(f"steward_disposition_not_allowed:{disposition}")
+    for field in (
+        "recurrence_fingerprint",
+        "what_happened",
+        "why_it_mattered",
+        "proposed_fix",
+    ):
+        if not str(event.get(field) or "").strip():
+            findings.append(f"{field}_required")
+    if not isinstance(event.get("inference_required"), bool):
+        findings.append("inference_required_boolean_required")
+    if event.get("raw_chain_of_thought") or event.get("chain_of_thought"):
+        findings.append("raw_chain_of_thought_not_allowed")
+
+    return {
+        "schema_id": "ion.carrier_friction_event_validation.v0",
+        "accepted": not findings,
+        "findings": findings,
+        "event_type": event_type or None,
+        "severity": severity or None,
+        "production_authority": False,
+        "live_execution_authority": False,
+    }
+
+
+def _load_ledger(root: Path) -> dict[str, Any]:
+    return _read_json(root / LEDGER_PATH) or {
+        "schema_id": SCHEMA_ID,
+        "created_at": _now(),
+        "updated_at": _now(),
+        "event_count": 0,
+        "recurrence_counts": {},
+        "severity_counts": {},
+        "events": [],
+        "production_authority": False,
+        "live_execution_authority": False,
+    }
+
+
+def record_friction_event(root: str | Path | None, event: Mapping[str, Any]) -> dict[str, Any]:
+    shell_root = _resolve_root(root)
+    validation = validate_friction_event(event)
+    if not validation["accepted"]:
+        return {
+            "schema_id": "ion.carrier_friction_record_result.v0",
+            "ok": False,
+            "verdict": BLOCKED_VERDICT,
+            "finding": "friction_event_validation_failed",
+            "validation": validation,
+            "production_authority": False,
+            "live_execution_authority": False,
+        }
+
+    recurrence = str(event.get("recurrence_fingerprint") or "").strip()
+    event_id = str(event.get("event_id") or "").strip()
+    if not event_id:
+        stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
+        event_id = f"friction_{stamp}_{_safe_slug(recurrence)}"
+
+    stored = dict(event)
+    stored.update(
+        {
+            "schema": EVENT_SCHEMA,
+            "event_id": event_id,
+            "created_at": str(event.get("created_at") or _now()),
+            "steward_disposition": str(event.get("steward_disposition") or "new"),
+            "production_authority": False,
+            "live_execution_authority": False,
+        }
+    )
+
+    event_path = shell_root / EVENTS_DIR / f"{_safe_slug(event_id)}.json"
+    counter = 1
+    while event_path.exists():
+        event_path = shell_root / EVENTS_DIR / f"{_safe_slug(event_id)}_{counter}.json"
+        counter += 1
+    _write_json(event_path, stored)
+
+    ledger = _load_ledger(shell_root)
+    recurrence_counts = dict(ledger.get("recurrence_counts") if isinstance(ledger.get("recurrence_counts"), Mapping) else {})
+    severity_counts = dict(ledger.get("severity_counts") if isinstance(ledger.get("severity_counts"), Mapping) else {})
+    recurrence_counts[recurrence] = int(recurrence_counts.get(recurrence, 0)) + 1
+    severity = str(stored.get("severity"))
+    severity_counts[severity] = int(severity_counts.get(severity, 0)) + 1
+    events = list(ledger.get("events") if isinstance(ledger.get("events"), list) else [])
+    rel_path = event_path.relative_to(shell_root).as_posix()
+    events.append(
+        {
+            "event_id": event_id,
+            "event_type": stored.get("event_type"),
+            "severity": severity,
+            "recurrence_fingerprint": recurrence,
+            "steward_disposition": stored.get("steward_disposition"),
+            "path": rel_path,
+            "created_at": stored.get("created_at"),
+        }
+    )
+    ledger.update(
+        {
+            "updated_at": _now(),
+            "event_count": len(events),
+            "recurrence_counts": recurrence_counts,
+            "severity_counts": severity_counts,
+            "events": events[-250:],
+            "latest_event_path": rel_path,
+        }
+    )
+    _write_json(shell_root / LEDGER_PATH, ledger)
+
+    return {
+        "schema_id": "ion.carrier_friction_record_result.v0",
+        "ok": True,
+        "verdict": READY_VERDICT,
+        "event_id": event_id,
+        "event_path": rel_path,
+        "ledger_path": LEDGER_PATH.as_posix(),
+        "recurrence_count": recurrence_counts[recurrence],
+        "production_authority": False,
+        "live_execution_authority": False,
+    }
+
+
+def build_friction_ledger_projection(root: str | Path | None, *, limit: int = 20) -> dict[str, Any]:
+    shell_root = _resolve_root(root)
+    ledger = _load_ledger(shell_root)
+    events = list(ledger.get("events") if isinstance(ledger.get("events"), list) else [])
+    bounded_limit = max(1, min(int(limit or 20), 100))
+    return {
+        "schema_id": "ion.carrier_friction_projection.v0",
+        "ok": True,
+        "verdict": READY_VERDICT,
+        "ledger_path": LEDGER_PATH.as_posix(),
+        "event_count": int(ledger.get("event_count") or 0),
+        "severity_counts": ledger.get("severity_counts") or {},
+        "recurrence_counts": ledger.get("recurrence_counts") or {},
+        "events": list(reversed(events[-bounded_limit:])),
+        "production_authority": False,
+        "live_execution_authority": False,
+    }

