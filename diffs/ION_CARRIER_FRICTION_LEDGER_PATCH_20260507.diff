--- a/ION/tests/test_kernel_ion_carrier_friction_ledger.py
+++ b/ION/tests/test_kernel_ion_carrier_friction_ledger.py
@@ -0,0 +1,73 @@
+from pathlib import Path
+
+from kernel.ion_carrier_friction_ledger import (
+    BLOCKED_VERDICT,
+    READY_VERDICT,
+    build_friction_ledger_projection,
+    record_friction_event,
+    validate_friction_event,
+)
+
+
+def _seed_root(root: Path) -> None:
+    (root / "pyproject.toml").write_text("[project]\nname = \"ion-friction-test\"\n", encoding="utf-8")
+    (root / "ION/REPO_AUTHORITY.md").parent.mkdir(parents=True, exist_ok=True)
+    (root / "ION/REPO_AUTHORITY.md").write_text("# authority\n", encoding="utf-8")
+
+
+def _event(**overrides):
+    event = {
+        "schema": "ion.carrier_friction_event.v0",
+        "event_type": "tool_hang",
+        "severity": "S3_BLOCKING",
+        "recurrence_fingerprint": "gateway_submit_hang_no_phase_receipt",
+        "what_happened": "Gateway submit returned no usable response.",
+        "why_it_mattered": "Carrier could not know whether mutation happened.",
+        "inference_required": True,
+        "missing_precondition": "Action status phase ledger.",
+        "immediate_workaround": "Inspect receipts and queue manually.",
+        "proposed_fix": "Add action status ledger and query.",
+        "fix_class": "gateway",
+    }
+    event.update(overrides)
+    return event
+
+
+def test_friction_event_validation_accepts_structured_event():
+    result = validate_friction_event(_event())
+
+    assert result["accepted"] is True
+    assert result["production_authority"] is False
+    assert result["live_execution_authority"] is False
+
+
+def test_friction_event_validation_rejects_raw_chain_of_thought():
+    result = validate_friction_event(_event(raw_chain_of_thought="hidden reasoning text"))
+
+    assert result["accepted"] is False
+    assert "raw_chain_of_thought_not_allowed" in result["findings"]
+
+
+def test_record_friction_event_writes_event_and_projection(tmp_path):
+    _seed_root(tmp_path)
+
+    result = record_friction_event(tmp_path, _event())
+    projection = build_friction_ledger_projection(tmp_path)
+
+    assert result["ok"] is True
+    assert result["verdict"] == READY_VERDICT
+    assert (tmp_path / result["event_path"]).exists()
+    assert (tmp_path / result["ledger_path"]).exists()
+    assert projection["event_count"] == 1
+    assert projection["severity_counts"]["S3_BLOCKING"] == 1
+
+
+def test_record_friction_event_blocks_invalid_event_without_write(tmp_path):
+    _seed_root(tmp_path)
+
+    result = record_friction_event(tmp_path, _event(event_type="not_allowed"))
+
+    assert result["ok"] is False
+    assert result["verdict"] == BLOCKED_VERDICT
+    assert "event_type_not_allowed:not_allowed" in result["validation"]["findings"]
+    assert not (tmp_path / "ION/05_context/current/carrier_friction/events").exists()

