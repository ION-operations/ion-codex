{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ion_mcp_hosted_storage_receipt_ledger_alpha_report.schema.json",
  "title": "ION MCP Hosted Storage Receipt Ledger Alpha Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "status",
    "passed",
    "created_at",
    "account_id",
    "workspace_id",
    "state_root_id",
    "object_ref_count",
    "receipt_event_count",
    "snapshot_count",
    "bundle_preview_count",
    "latest_event_hash",
    "allowed_resolutions",
    "forbidden_tool_count",
    "event_chain_verified",
    "content_addressed_state_root_verified",
    "append_only_ledger_verified",
    "bundle_preview_verified",
    "hosted_cloud_certified",
    "public_endpoint_certified",
    "kubernetes_certified",
    "production_object_storage_certified",
    "live_execution_authorized_seen",
    "kernel_truth_mutation_seen",
    "forbidden_resolution_seen",
    "forbidden_event_seen",
    "denied_reasons"
  ],
  "properties": {
    "version": {"type": "string", "const": "V71_HOSTED_MCP_STORAGE_AND_RECEIPT_LEDGER_ALPHA"},
    "status": {"type": "string", "enum": ["ACCEPTED", "REFUSED", "DEGRADED"]},
    "passed": {"type": "boolean"},
    "created_at": {"type": "string"},
    "account_id": {"type": "string"},
    "workspace_id": {"type": "string"},
    "state_root_id": {"type": "string"},
    "object_ref_count": {"type": "integer", "minimum": 0},
    "receipt_event_count": {"type": "integer", "minimum": 0},
    "snapshot_count": {"type": "integer", "minimum": 0},
    "bundle_preview_count": {"type": "integer", "minimum": 0},
    "latest_event_hash": {"type": ["string", "null"]},
    "allowed_resolutions": {
      "type": "array",
      "items": {"type": "string", "enum": ["READ_ONLY", "DRY_RUN", "APPROVAL_REQUIRED", "REFUSED"]},
      "uniqueItems": true
    },
    "forbidden_tool_count": {"type": "integer", "minimum": 0},
    "event_chain_verified": {"type": "boolean"},
    "content_addressed_state_root_verified": {"type": "boolean"},
    "append_only_ledger_verified": {"type": "boolean"},
    "bundle_preview_verified": {"type": "boolean"},
    "hosted_cloud_certified": {"type": "boolean", "const": false},
    "public_endpoint_certified": {"type": "boolean", "const": false},
    "kubernetes_certified": {"type": "boolean", "const": false},
    "production_object_storage_certified": {"type": "boolean", "const": false},
    "live_execution_authorized_seen": {"type": "boolean", "const": false},
    "kernel_truth_mutation_seen": {"type": "boolean", "const": false},
    "forbidden_resolution_seen": {"type": "boolean", "const": false},
    "forbidden_event_seen": {"type": "boolean", "const": false},
    "denied_reasons": {"type": "array", "items": {"type": "string"}}
  }
}
