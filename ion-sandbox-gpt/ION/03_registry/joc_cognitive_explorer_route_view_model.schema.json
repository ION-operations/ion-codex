{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ion.joc_cognitive_explorer_route_view_model.v1",
  "title": "ION/JOC Cognitive Explorer Route View Model Receipt",
  "type": "object",
  "required": [
    "version",
    "schema_id",
    "receipt_id",
    "authority_scope",
    "route_verdict",
    "query",
    "selected_node_count",
    "dependency_edge_count",
    "route_classes",
    "view_surfaces",
    "source_citations",
    "forbidden_capabilities",
    "production_authority",
    "live_ui_claim"
  ],
  "properties": {
    "version": { "const": "V58_COGNITIVE_EXPLORER_AND_CONTEXT_ROUTE_VIEW_MODEL" },
    "schema_id": { "const": "ion.joc_cognitive_explorer_route_view_model.v1" },
    "receipt_id": { "type": "string" },
    "generated_at": { "type": "string" },
    "authority_scope": { "const": "COGNITIVE_EXPLORER_ROUTE_VIEW_MODEL_RECEIPT_ONLY" },
    "route_verdict": { "type": "string" },
    "query": { "type": "string" },
    "selected_node_count": { "type": "integer", "minimum": 0 },
    "dependency_edge_count": { "type": "integer", "minimum": 0 },
    "route_class_count": { "type": "integer", "minimum": 0 },
    "view_surface_count": { "type": "integer", "minimum": 0 },
    "citation_count": { "type": "integer", "minimum": 0 },
    "selected_nodes": { "type": "array" },
    "dependency_edges": { "type": "array" },
    "route_classes": { "type": "array", "items": { "type": "string" } },
    "view_surfaces": { "type": "array", "items": { "type": "string" } },
    "source_citations": { "type": "array", "items": { "type": "string" } },
    "route_reasoning": { "type": "string" },
    "injection_preview": { "type": "string" },
    "findings": { "type": "array", "items": { "type": "string" } },
    "forbidden_capabilities": { "type": "object" },
    "production_authority": { "const": false },
    "live_ui_claim": { "const": false }
  }
}
