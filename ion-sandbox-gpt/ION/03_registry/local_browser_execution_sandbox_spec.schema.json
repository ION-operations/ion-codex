{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ion.local_browser_execution_sandbox_spec.v1",
  "title": "ION Local Browser Execution Sandbox Spec Receipt",
  "type": "object",
  "required": [
    "schema_id",
    "version",
    "spec_id",
    "spec_name",
    "sandbox_spec_status",
    "target_origin_policy",
    "network_policy",
    "credential_policy",
    "navigation_policy",
    "mutation_policy",
    "file_write_policy",
    "steward_gate_status",
    "required_controls",
    "spec_verdict",
    "authority_scope",
    "browser_execution_authorized",
    "production_authority",
    "forbidden_capabilities"
  ],
  "properties": {
    "schema_id": {"const": "ion.local_browser_execution_sandbox_spec.v1"},
    "version": {"const": "V51_LOCAL_BROWSER_EXECUTION_SANDBOX_SPEC"},
    "spec_id": {"type": "string"},
    "emitted_at": {"type": "string"},
    "spec_name": {"type": "string"},
    "lineage_refs": {"type": "array", "items": {"type": "string"}},
    "sandbox_spec_status": {"enum": ["SPEC_ONLY", "STEWARD_REVIEW_REQUIRED", "BLOCKED"]},
    "target_origin_policy": {"enum": ["LOCAL_FILES_OR_LOOPBACK_ONLY", "LOOPBACK_ONLY", "UNREVIEWED", "BLOCKED"]},
    "network_policy": {"enum": ["NO_EXTERNAL_NETWORK", "NO_NETWORK", "UNREVIEWED", "BLOCKED"]},
    "credential_policy": {"enum": ["NO_CREDENTIALS_OR_SESSION_IMPORT", "SANITIZED_TEST_FIXTURES_ONLY", "UNREVIEWED", "BLOCKED"]},
    "navigation_policy": {"enum": ["FIXTURE_MANIFEST_ONLY", "SINGLE_URL_ALLOWLIST_ONLY", "UNREVIEWED", "BLOCKED"]},
    "mutation_policy": {"enum": ["NO_PERSISTENT_MUTATION", "TEMPORARY_TEST_INSTRUMENTATION_ONLY", "UNREVIEWED", "BLOCKED"]},
    "file_write_policy": {"enum": ["RECEIPTS_AND_CAPTURE_ARTIFACTS_ONLY", "RECEIPTS_ONLY", "UNREVIEWED", "BLOCKED"]},
    "steward_gate_status": {"enum": ["APPROVED_SPEC_ONLY", "STEWARD_REVIEW_REQUIRED", "BLOCKED"]},
    "required_controls": {"type": "array", "items": {"type": "string"}},
    "review_findings": {"type": "array", "items": {"type": "string"}},
    "spec_verdict": {"enum": ["LOCAL_BROWSER_SANDBOX_SPEC_ACCEPTED_SPEC_ONLY", "LOCAL_BROWSER_SANDBOX_SPEC_NEEDS_REMEDIATION", "LOCAL_BROWSER_SANDBOX_SPEC_REJECTED_FOR_FORBIDDEN_CAPABILITY", "LOCAL_BROWSER_SANDBOX_SPEC_BLOCKED_BY_STEWARD"]},
    "recommended_next_actions": {"type": "array", "items": {"type": "string"}},
    "authority_scope": {"const": "LOCAL_DEV_BROWSER_EXECUTION_SANDBOX_SPEC_ONLY"},
    "browser_execution_authorized": {"const": false},
    "production_authority": {"const": false},
    "forbidden_capabilities": {"type": "object", "additionalProperties": {"const": false}}
  },
  "additionalProperties": true
}
