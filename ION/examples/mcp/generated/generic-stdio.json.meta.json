{
  "client": "Generic MCP-compatible host",
  "config": {
    "args": [
      "-m",
      "kernel.ion_mcp_local_bridge",
      "--ion-root",
      "/mnt/data/ion_v64_work/ION MASTER CURRENT/ION",
      "--stdio"
    ],
    "command": "python",
    "env": {
      "PYTHONPATH": "/mnt/data/ion_v64_work/ION MASTER CURRENT/ION/04_packages"
    },
    "first_calls": [
      "initialize",
      "tools/list",
      "tools/call ion.mount",
      "tools/call ion.status"
    ],
    "forbidden": [
      "ion.job.execute_live",
      "ion.shell.run",
      "ion.provider.dispatch",
      "ion.browser.mutate"
    ],
    "name": "ion-local",
    "transport": "stdio"
  },
  "filename": "generic-stdio.json",
  "notes": [
    "Canonical local stdio bridge command profile.",
    "This is the source profile from which client-specific profiles should be derived."
  ],
  "profile_name": "generic-local-stdio"
}
