[Unit]
Description=ION Local Cockpit Browser App
After=network.target

[Service]
Type=simple
WorkingDirectory=__ION_ROOT__
Environment=PYTHONDONTWRITEBYTECODE=1
Environment=PYTHONPATH=__ION_PYTHONPATH__
ExecStart=/usr/bin/python3 -S -m kernel.ion_local_cockpit_app --ion-root . --host 127.0.0.1 --port 8788 --serve
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=default.target
